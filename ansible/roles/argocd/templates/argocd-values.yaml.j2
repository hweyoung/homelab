global:
  domain: "{{ argocd_domain }}"

configs:
  params:
    # ArgoCD 자체는 HTTP 로 서비스하고 SSL 은 Ingress(Traefik) 에서 처리합니다.
    # 이 옵션이 없으면 ArgoCD 가 HTTPS 로 리다이렉트하면서 무한 루프가 발생합니다.
    server.insecure: "true"
  cm:
    # ksops 를 사용하기 위한 kustomize alpha plugin / exec 허용.
    kustomize.buildOptions: "--enable-alpha-plugins --enable-exec"

server:
  ingress:
    enabled: true
    ingressClassName: "{{ argocd_ingress_class }}"
    annotations:
      traefik.ingress.kubernetes.io/service.serversscheme: "http"

# ksops integration:
#   1. initContainer 가 ksops 바이너리를 emptyDir 에 풀어 둠
#   2. argocd-repo-server 에 emptyDir + sops-age Secret 을 마운트
#   3. SOPS_AGE_KEY_FILE 환경변수가 age 키 파일 경로를 가리킴
# sops_bootstrap role 이 argocd ns 에 sops-age Secret 을 먼저 만들어 두어야 합니다.
repoServer:
  initContainers:
    - name: install-ksops
      image: viaductoss/ksops:v4.3.3
      command: ["/bin/sh", "-c"]
      args:
        - |
          echo "Installing KSOPS..." && \
          mv ksops /custom-tools/ && \
          mv kustomize /custom-tools/ && \
          echo "Done."
      volumeMounts:
        - mountPath: /custom-tools
          name: custom-tools
  volumes:
    - name: custom-tools
      emptyDir: {}
    - name: sops-age
      secret:
        secretName: sops-age
  volumeMounts:
    - mountPath: /usr/local/bin/kustomize
      name: custom-tools
      subPath: kustomize
    - mountPath: /usr/local/bin/ksops
      name: custom-tools
      subPath: ksops
    - mountPath: /home/argocd/.config/sops/age/keys.txt
      name: sops-age
      subPath: keys.txt
      readOnly: true
  env:
    - name: SOPS_AGE_KEY_FILE
      value: /home/argocd/.config/sops/age/keys.txt
    - name: XDG_CONFIG_HOME
      value: /home/argocd/.config
