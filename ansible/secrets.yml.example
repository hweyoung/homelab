---
# 사용 흐름:
#   cp secrets.example.yml secrets.yml
#   ansible-vault encrypt secrets.yml
# 실행:
#   ansible-playbook site.yml -e @secrets.yml --ask-vault-pass

# Tailscale 재사용 가능한 auth key (tskey-auth-... 형식)
tailscale_auth_key: "CHANGE_ME"

# SOPS age 비공개키 (AGE-SECRET-KEY-... 로 시작).
# `age-keygen -o age.key` 로 생성하고, 공개키(첫줄 주석) 는
# gitops/.sops.yaml 의 creation_rules[].age 에 박아 둡니다.
sops_age_private_key: "CHANGE_ME"

# Github Repo PAT-token
argocd_repo_pat: "CHANGE_ME"

# 그 외 GitOps 시크릿(Cloudflare, Dex, MinIO, DB 자격증명 등)은
# Ansible Vault 가 아니라 클러스터 내 SOPS + age 로 관리합니다.

